# Format staged files with Biome
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.(js|jsx|ts|tsx|json|jsonc)$' || true)

if [ -n "$STAGED_FILES" ]; then
  echo "Formatting staged files with Biome..."
  echo "$STAGED_FILES" | xargs ./node_modules/.bin/biome format --write
  echo "$STAGED_FILES" | xargs git add
fi

./node_modules/.bin/nx typecheck core && ./node_modules/.bin/nx typecheck data-transfer
