{
  "exportFolder": "dist/lingo-export",
  "importFolder": "dist/lingo-import",
  "baseLocale": "en",
  "locales": [
    "en",
    "fr-ca",
    "es",
    "de",
    "ja"
  ],
  "collections": {
    "TestDataPlayground": {
      "translationsFolder": "sample-translations/playground",
      "locales": [
        "en",
        "fr-ca",
        "es",
        "de",
        "ja"
      ]
    },
    "TestDataDesignSystem": {
      "translationsFolder": "sample-translations/design-system"
    },
    "TestDataCore": {
      "translationsFolder": "sample-translations/core"
    },
    "Web": {
      "translationsFolder": "apps/web/src/i18n"
    },
    "trackerResources": {
      "translationsFolder": "apps/tracker/src/assets/i18n",
      "locales": []
    }
  },
  "bundles": {
    "main": {
      "bundleName": "{locale}",
      "dist": "./dist/i18n",
      "collections": "All",
      "typeDist": "./dist/i18n-types/main.ts"
    }
  }
}