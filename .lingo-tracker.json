{
  "exportFolder": "dist/lingo-export",
  "importFolder": "dist/lingo-import",
  "baseLocale": "en",
  "locales": [
    "en",
    "fr-ca",
    "es",
    "de",
    "ja"
  ],
  "collections": {
    "TestDataPlayground": {
      "translationsFolder": "sample-translations/playground",
      "locales": [
        "en",
        "fr-ca",
        "es",
        "de",
        "ja"
      ]
    },
    "trackerResources": {
      "translationsFolder": "apps/tracker/src/i18n",
      "locales": [
        "en",
        "es",
        "fr-ca"
      ]
    },
    "mockDesignSystem": {
      "translationsFolder": "sample-translations/mock-design-system",
      "importFolder": "dist/ds-translations",
      "locales": [
        "ar",
        "de",
        "es",
        "fr-ca",
        "fr-fr",
        "is",
        "ja",
        "ko",
        "nl",
        "pt-br",
        "sv"
      ]
    }
  },
  "translation": {
    "enabled": true,
    "provider": "google-translate",
    "apiKeyEnv": "GOOGLE_TRANSLATE_API_KEY"
  },
  "bundles": {
    "main": {
      "bundleName": "{locale}",
      "dist": "./dist/i18n",
      "collections": "All",
      "typeDist": "./dist/i18n-types/main.ts"
    },
    "tracker": {
      "bundleName": "{locale}",
      "dist": "./apps/tracker/src/assets/i18n",
      "collections": [
        {
          "name": "trackerResources",
          "entriesSelectionRules": "All"
        }
      ],
      "typeDist": "./apps/tracker/src/i18n-types/tracker-resources.ts"
    }
  }
}