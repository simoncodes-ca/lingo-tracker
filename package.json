{
  "name": "@simoncodes-ca/lingo-tracker",
  "version": "0.10.0",
  "description": "Effortlessly Track, Validate, and Manage Your Translations.",
  "bin": {
    "lingo-tracker": "dist/apps/cli/main.cjs",
    "lingo-tracker-app": "dist/apps/api/main.js"
  },
  "scripts": {
    "build:cli": "nx build cli",
    "build:api": "nx build api",
    "prebuild:tracker": "node dist/apps/cli/main.cjs bundle --name tracker",
    "build:tracker": "nx build tracker",
    "build": "pnpm run build:cli && pnpm run build:api && pnpm run build:tracker",
    "serve:api": "nx serve api",
    "serve:tracker": "nx serve tracker",
    "prepare": "husky",
    "commit": "git-cz",
    "release": "semantic-release",
    "test:api": "nx test api",
    "test:cli": "nx test cli",
    "test:core": "nx test core",
    "test:tracker": "nx test tracker",
    "test": "pnpm run test:cli && pnpm run test:api && pnpm run test:core &&pnpm run test:tracker",
    "test:release": "pnpm run release --dry-run",
    "typecheck:core": "nx typecheck core",
    "typecheck:data-transfer": "nx typecheck data-transfer",
    "typecheck": "pnpm run typecheck:core && pnpm run typecheck:data-transfer",
    "nx": "nx",
    "lint": "pnpm exec biome lint apps libs scripts types",
    "format": "pnpm exec biome format --write apps libs scripts types",
    "format:check": "pnpm exec biome format apps libs scripts types",
    "format:write": "pnpm exec biome format --write apps libs scripts types",
    "lingo-tracker": "node dist/apps/cli/main.cjs"
  },
  "keywords": [
    "translation",
    "i18n",
    "internationalization",
    "localization",
    "l10n",
    "transloco",
    "translation-management",
    "icu",
    "cli",
    "angular"
  ],
  "author": "Simon Nodel",
  "private": false,
  "repository": {
    "type": "git",
    "url": "https://github.com/simoncodes-ca/lingo-tracker.git"
  },
  "homepage": "https://github.com/simoncodes-ca/lingo-tracker#readme",
  "bugs": {
    "url": "https://github.com/simoncodes-ca/lingo-tracker/issues"
  },
  "files": [
    "dist/apps/cli",
    "dist/apps/api",
    "dist/apps/tracker",
    "docs"
  ],
  "publishConfig": {
    "access": "public"
  },
  "license": "MIT",
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=20",
    "pnpm": ">=10"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/cz-conventional-changelog"
    }
  },
  "pnpm": {
    "overrides": {
      "axios": ">=1.13.5",
      "tar": ">=7.5.11",
      "multer": ">=2.1.1",
      "svgo": ">=3.3.3",
      "immutable": ">=5.1.5",
      "@tootallnate/once": ">=3.0.1",
      "koa": ">=3.1.2",
      "minimatch@<3.1.4": "3.1.4",
      "minimatch@>=5.0.0 <5.1.7": "5.1.7",
      "minimatch@>=9.0.0 <9.0.6": "9.0.6",
      "minimatch@>=10.0.0 <10.2.1": "10.2.1",
      "ajv@<6.14.0": "6.14.0",
      "ajv@>=7.0.0-alpha.0 <8.18.0": "8.18.0",
      "rollup": ">=4.59.0",
      "webpack@>=5.49.0 <5.104.1": "5.104.1",
      "@modelcontextprotocol/sdk": ">=1.26.0",
      "@isaacs/brace-expansion": ">=5.0.1",
      "diff@>=4.0.0 <4.0.4": "4.0.4",
      "qs@>=6.7.0 <6.14.2": "6.14.2",
      "file-type@>=13.0.0 <21.3.1": "21.3.1",
      "lodash-es": ">=4.17.23",
      "lodash": ">=4.17.23"
    }
  },
  "nx": {},
  "dependencies": {
    "@angular/cdk": "^20.2.5",
    "@angular/common": "~20.2.0",
    "@angular/compiler": "~20.2.0",
    "@angular/core": "~20.2.0",
    "@angular/forms": "~20.2.0",
    "@angular/material": "^20.2.5",
    "@angular/platform-browser": "~20.2.0",
    "@angular/router": "~20.2.0",
    "@jsverse/transloco": "^8.0.2",
    "@jsverse/transloco-messageformat": "^8.2.1",
    "@jsverse/utils": "1.0.0-beta.5",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/serve-static": "^5.0.3",
    "@nestjs/swagger": "^11.2.0",
    "@ngrx/signals": "^20.0.1",
    "commander": "^14.0.1",
    "express": "^5.2.1",
    "prompts": "^2.4.2",
    "reflect-metadata": "^0.1.13",
    "rxjs": "~7.8.0",
    "tslib": "^2.8.1",
    "xliff": "^6.2.2",
    "zone.js": "~0.15.0"
  },
  "devDependencies": {
    "@analogjs/vite-plugin-angular": "~1.19.1",
    "@analogjs/vitest-angular": "~1.19.1",
    "@angular-devkit/core": "~20.2.0",
    "@angular-devkit/schematics": "~20.2.0",
    "@angular/build": "~20.2.0",
    "@angular/cli": "~20.2.0",
    "@angular/compiler-cli": "~20.2.0",
    "@angular/language-service": "~20.2.0",
    "@angular/platform-browser-dynamic": "^20.2.4",
    "@biomejs/biome": "2.3.13",
    "@commitlint/cli": "19.8.0",
    "@commitlint/config-conventional": "19.8.0",
    "@eslint/js": "^9.8.0",
    "@nestjs/schematics": "^11.0.0",
    "@nestjs/testing": "^11.0.0",
    "@ngneat/spectator": "^22.0.0",
    "@ngrx/signals": "^20.0.1",
    "@nx/angular": "21.5.3",
    "@nx/esbuild": "21.5.3",
    "@nx/eslint": "21.5.3",
    "@nx/eslint-plugin": "21.5.3",
    "@nx/jest": "21.5.3",
    "@nx/js": "21.5.3",
    "@nx/nest": "21.5.3",
    "@nx/node": "21.5.3",
    "@nx/vite": "21.5.3",
    "@nx/web": "21.5.3",
    "@nx/webpack": "21.5.3",
    "@schematics/angular": "~20.2.0",
    "@semantic-release/changelog": "^6.0.3",
    "@semantic-release/commit-analyzer": "^13.0.1",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/release-notes-generator": "^14.0.3",
    "@swc-node/register": "~1.9.1",
    "@swc/core": "~1.13.5",
    "@swc/helpers": "~0.5.11",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/lodash": "^4.17.20",
    "@types/node": "20.19.9",
    "@types/prompts": "^2.4.9",
    "@typescript-eslint/utils": "^8.40.0",
    "@vitest/coverage-v8": "^3.0.5",
    "@vitest/ui": "^3.0.0",
    "angular-eslint": "^20.2.0",
    "commitizen": "4.3.1",
    "cz-conventional-changelog": "3.3.0",
    "esbuild": "^0.19.2",
    "eslint": "^9.8.0",
    "eslint-config-prettier": "^10.0.0",
    "husky": "9.1.7",
    "jest": "^30.0.2",
    "jest-environment-node": "^30.0.2",
    "jest-util": "^30.0.2",
    "jiti": "2.4.2",
    "jsdom": "~22.1.0",
    "jsonc-eslint-parser": "^2.1.0",
    "lodash": "^4.17.21",
    "nx": "21.5.3",
    "prettier": "^2.6.2",
    "semantic-release": "^24.2.3",
    "ts-jest": "^29.4.0",
    "ts-node": "10.9.1",
    "typescript": "~5.9.2",
    "typescript-eslint": "^8.40.0",
    "vite": "^7.0.0",
    "vite-plugin-dts": "~4.5.0",
    "vitest": "^3.0.0",
    "webpack-cli": "^5.1.4"
  }
}
